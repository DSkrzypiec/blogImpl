---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostLink from "../../components/PostLink.astro";

// Only posts that have a Polish version are listed here.
const posts = [
  {
    "title": "Warzenie piwa, a inżynieria oprogramowania",
    "date": "2026-06-27",
    "tags": ["Ogólne"],
    "href": "/pl/beer"
  }
];
---

<BaseLayout altLocaleUrl="/">
  <section class="post-list">
    {posts.map((post) => (
      <PostLink {...post} />
    ))}
  </section>
</BaseLayout>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    align-items: center; /* Center the posts */
    gap: 1rem; /* Add spacing between posts */
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem;
    width: 100%;
    box-sizing: border-box;
  }

  /* Mobile responsive adjustments */
  @media (max-width: 480px) {
    .post-list {
      padding: 0.5rem;
      gap: 0.75rem;
    }
  }
</style>
