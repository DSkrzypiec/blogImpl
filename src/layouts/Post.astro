---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import TableOfContents from "../components/TableOfContents.astro";

export interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title || "Blog Post"}</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.26/dist/katex.min.css"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <header>
      <Nav />
    </header>

    <!-- 
      1) Wrap sidebar + main in a single parent .post-layout
         so flexbox can place them side by side on large screens 
    -->
    <div class="post-layout">
      <!-- SIDEBAR -->
      <aside class="post-layout-sidebar">
        <TableOfContents />
      </aside>

      <!-- MAIN CONTENT AREA -->
      <div class="post-layout-content">
        <main>
          <article>
            <slot />
          </article>
        </main>
      </div>
    </div>
  </body>

  <style>
    main {
      padding: 2rem 1rem; /* Add proper padding */
      max-width: 900px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
    }

    /* Desktop layout adjustments */
    @media (min-width: 1024px) {
      main {
        padding: 2rem 0; /* Remove side padding on desktop since layout container handles it */
        max-width: none; /* Let the layout container handle max-width */
      }
    }

    /* Mobile responsive padding */
    @media (max-width: 768px) {
      main {
        padding: 1.5rem 0.75rem;
      }
    }

    @media (max-width: 480px) {
      main {
        padding: 1rem 0.5rem;
      }
    }

    article {
      max-width: 800px;
      width: 100%;
      margin: 0 auto; /* center the article text horizontally */
      color: var(--text-primary);
      box-sizing: border-box;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    h1, h2, h3 {
      color: var(--accent-color);
      margin-top: 1.5rem; /* reduce to 0 if you want no top gap */
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    p {
      color: var(--text-secondary);
      word-wrap: break-word;
      overflow-wrap: break-word;
      hyphens: auto;
    }

    img {
      max-width: 100%;
      max-height: 400px;
      width: auto;
      height: auto;
      border-radius: 8px;
      margin: 1rem 0;
      object-fit: contain;
    }

    /* Responsive image sizing */
    @media (max-width: 768px) {
      img {
        max-height: 300px;
      }
    }

    @media (max-width: 480px) {
      img {
        max-height: 250px;
      }
    }

    blockquote {
      border-left: 4px solid var(--accent-color);
      padding-left: 1rem;
      color: var(--text-primary);
      font-style: italic;
      margin: 1rem 0;
    }

    code {
      font-family: monospace;
      background: rgba(255, 255, 255, 0.1);
      padding: 0.2rem 0.4rem;
      border-radius: 4px;
      font-size: 0.95rem;
    }
  </style>

  <!-- Global styles for .post-layout and .post-layout-sidebar -->
  <style is:global>
    /* The parent container that wraps sidebar + content */
    .post-layout {
      display: flex;
      flex-direction: row;
    }

    /* Side-by-side on larger screens */
    @media (min-width: 1024px) {
      .post-layout {
        flex-direction: row;
      }

      .post-layout-sidebar {
        position: fixed;
        left: 2rem;
        top: 10rem;
        width: 200px;
        font-size: 0.85rem;
        padding: 1rem;
        z-index: 10;
      }

      .post-layout-content {
        flex: 1;
        max-width: 1000px; /* Increased from 800px for better laptop utilization */
        margin: 0 auto; /* Center the content */
        padding-left: 240px; /* Offset for fixed sidebar (200px + 2rem + padding) */
        padding-right: 2rem; /* Add right padding for balance */
      }
    }

    /* Larger screens get even more width */
    @media (min-width: 1400px) {
      .post-layout-content {
        max-width: 1200px; /* Even wider on large screens */
      }
    }

    /* Hide sidebar on small screens if desired */
    .post-layout-sidebar {
      display: none;
    }
    @media (min-width: 1024px) {
      .post-layout-sidebar {
        display: block;
      }
    }

    /* Mobile responsive adjustments */
    @media (max-width: 1023px) {
      .post-layout {
        flex-direction: column;
      }
      
      .post-layout-content {
        width: 100%;
        max-width: 100%;
      }
    }

    /* Make Code components fit full width */
    :global(pre) {
      width: 100% !important;
      max-width: 100% !important;
      overflow-x: auto;
      box-sizing: border-box;
    }

    :global(.astro-code) {
      width: 100% !important;
      max-width: 100% !important;
      box-sizing: border-box;
    }

    :global(.astro-code pre) {
      width: 100% !important;
      max-width: 100% !important;
      overflow-x: auto;
      box-sizing: border-box;
    }

    /* Ensure code blocks don't exceed container width */
    :global(.post-layout-content pre) {
      max-width: 100% !important;
      overflow-x: auto;
      word-wrap: break-word;
      white-space: pre-wrap;
    }
  </style>
</html>

