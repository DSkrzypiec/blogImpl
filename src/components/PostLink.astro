---
export interface Props {
  title: string;
  date: string;
  tags?: string[];
  href: string;
}

const { title, date, tags, href } = Astro.props;
---

<a href={href} class="post-link">
  <div class="post-content">
    <h2>{title}</h2>
    <p class="post-date">{date}</p>
    {tags && (
      <ul class="post-tags">
        {tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )}
  </div>
</a>

<style>
  .post-link {
    display: block;
    width: 100%; /* Take full parent width */
    max-width: 900px; /* Set a max width for better readability */
    padding: 0.5rem;
    margin: 0 auto 0.5rem auto; /* Center and add spacing below */
    text-decoration: none;
    background-color: rgba(255, 255, 255, 0.02);
    transition: transform 0.2s ease, background-color 0.2s ease;
    box-sizing: border-box; /* Include padding in width calculation */
    word-wrap: break-word; /* Break long words */
    overflow-wrap: break-word; /* Modern word wrapping */
  }

  /* Mobile responsive adjustments */
  @media (max-width: 480px) {
    .post-link {
      padding: 0.4rem;
      margin: 0 auto 0.4rem auto;
    }
    
    h2 {
      font-size: 1.2rem;
    }
  }

  .post-link:hover {
    background-color: rgba(255, 255, 255, 0.1);
    transform: scale(1.02);
  }

  .post-link:hover h2 {
    color: var(--accent-color);
  }

  .post-link:hover .post-date {
    color: var(--text-primary);
    font-weight: bold;
  }

  .post-content {
    display: flex;
    flex-direction: column;
  }

  h2 {
    margin: 0;
    font-size: 1.4rem;
    color: var(--text-primary);
  }

  .post-date {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-tags li {
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    border: 1px solid var(--text-secondary);
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.05);
  }
</style>
